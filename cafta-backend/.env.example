# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:senha@localhost:5432/cafta_db

# ─── Upload ───────────────────────────────────────────────────────────────────
# Tamanho máximo de upload em MB (aplicado pelo multer antes do envio ao R2)
UPLOAD_MAX_MB=100

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
# Encontrado em: Cloudflare Dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=seu_account_id_aqui

# Gerar em: Cloudflare Dashboard → R2 → Manage R2 API Tokens → Create API Token
# Permissões necessárias: Object Read & Write no bucket cafta-acervo
R2_ACCESS_KEY_ID=sua_access_key_id_aqui
R2_SECRET_ACCESS_KEY=sua_secret_access_key_aqui

# Nome do bucket criado no painel do R2
R2_BUCKET_NAME=cafta-acervo

# URL pública do bucket.
# Opção A — domínio próprio (recomendado): https://acervo.cafta.ufc.br
# Opção B — subdomínio gratuito do R2 (ativar em R2 → Settings → Public Access):
#            https://<hash>.r2.dev
R2_PUBLIC_URL=https://acervo.cafta.ufc.br

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Rate Limit ───────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX=100

# Next.js API Route Configuration
# Use these to configure the API base URL for frontend-backend communication

# During development, you can leave this empty to use relative URLs (same origin)
# Or set it explicitly to your backend URL
NEXT_PUBLIC_API_URL=

# Example for development with local backend:
# NEXT_PUBLIC_API_URL=http://localhost:4000

# Example for production (when frontend is on Vercel and backend on Render):
# NEXT_PUBLIC_API_URL=https://cafta-acervo-digital.onrender.com

# Note: When deploying to Vercel, set this in the Vercel project settings
# under Environment Variables